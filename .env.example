OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional LangSmith tracing. Set LANGSMITH_TRACING=true and paste your key
# to enable — every LangChain/LangGraph call shows up at smith.langchain.com.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=C6-Hackathon-Group-4
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# General runtime settings.
ENVIRONMENT=local
LOG_LEVEL=INFO

# Comma-separated origins allowed by the FastAPI server.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Optional placeholders for future real Slack/JIRA clients.
# Current hackathon demo mode uses mock outputs and does not require these.
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#hackathon-incidents
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=you@example.com
JIRA_TOKEN=
JIRA_PROJECT_KEY=OPS
